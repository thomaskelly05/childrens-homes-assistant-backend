# Server-only: upstream for /backend proxy (production: https://api.indicare.co.uk)
INTERNAL_API_BASE_URL=http://127.0.0.1:8000

# Do NOT set these to onrender.com for app.indicare.co.uk — Safari blocks cross-site session cookies.
# Leave unset in production; the browser uses same-origin /backend instead.
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_APP_NAME=IndiCare OS
NEXT_PUBLIC_ENVIRONMENT=production

# Founder dashboard data mode: live-only (default in production), hybrid, or mock (dev/testing only)
FOUNDER_DATA_MODE=live-only

# IndiCare Lab shadow review (Phase 3) — browser flags need NEXT_PUBLIC_ prefix
# NEXT_PUBLIC_INDICARE_LAB_SHADOW_REVIEW_ENABLED=0
# NEXT_PUBLIC_INDICARE_LAB_STORE_FULL_TEXT=0
# NEXT_PUBLIC_INDICARE_LAB_REDACT_NAMES=1
# NEXT_PUBLIC_INDICARE_LAB_MAX_REVIEW_TEXT_LENGTH=2000
