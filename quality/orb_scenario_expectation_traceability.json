{
  "version": "1.0.0",
  "description": "Scenario family and record-type expectation to source traceability for ORB Residential Quality Lab.",
  "last_reviewed_date": "2026-06-15",
  "required_element_mappings": [
    {
      "element": "child voice/presentation",
      "what_is_expected": "Record what the child said, showed or how they presented — without inventing quotes.",
      "external_source_ids": [
        "guide_ch_reg_quality_standards",
        "nice_looked_after_children",
        "children_act_1989"
      ],
      "internal_source_ids": ["indicare_record_dignity", "indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "factual observations",
      "what_is_expected": "Observable facts, sequence and what staff saw or heard.",
      "external_source_ids": [
        "guide_ch_reg_quality_standards",
        "ofsted_ch_inspection_guidance",
        "swe_professional_standards"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "adult response",
      "what_is_expected": "Specific adult actions, support offered, de-escalation and attuned response.",
      "external_source_ids": [
        "guide_ch_reg_quality_standards",
        "pace_principles",
        "trauma_informed_principles"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "medium"
    },
    {
      "element": "emotional support",
      "what_is_expected": "Validation, comfort, regulation support and relational response documented.",
      "external_source_ids": [
        "nice_looked_after_children",
        "pace_principles",
        "ddp_principles"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "medium"
    },
    {
      "element": "outcome",
      "what_is_expected": "What changed by the end of the interaction or shift.",
      "external_source_ids": [
        "guide_ch_reg_quality_standards",
        "ofsted_sccif_ch"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "follow-up",
      "what_is_expected": "Next steps, outstanding actions, review dates or continuity for next shift.",
      "external_source_ids": [
        "working_together_2023",
        "ofsted_ch_inspection_guidance"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "management oversight",
      "what_is_expected": "Manager notification, debrief, supervision or oversight where proportionate.",
      "external_source_ids": [
        "ch_reg_2015",
        "guide_ch_reg_quality_standards",
        "ofsted_ch_inspection_guidance"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "escalation/pathway",
      "what_is_expected": "Proportionate pathway language — routine follow-up, handover, senior/manager review, local safeguarding procedure, professional consultation or urgent action where indicated. Record who was informed and what remains unresolved. ORB suggests consideration; responsible adults decide per local policy.",
      "external_source_ids": [
        "working_together_2023",
        "nspcc_safeguarding_guidance",
        "local_safeguarding_procedures",
        "ofsted_safeguarding_expectations"
      ],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high",
      "boundary_note": "Pathways are for professional consideration, not ORB decision-making. Local policy remains authoritative. Internal quality indicator, not regulatory judgement."
    },
    {
      "element": "source/evidence basis",
      "what_is_expected": "Evidence linked to chronology, records reviewed, gaps acknowledged.",
      "external_source_ids": [
        "ofsted_ch_inspection_guidance",
        "ofsted_sccif_ch"
      ],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "adult review requirement",
      "what_is_expected": "Draft-only caveat; professional judgement and local policy boundary stated.",
      "external_source_ids": [
        "swe_professional_standards",
        "working_together_2023"
      ],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    }
  ],
  "prohibited_element_mappings": [
    {
      "element": "blame",
      "what_is_prohibited": "Attributing fault, motive or punitive labels to the child.",
      "external_source_ids": ["guide_ch_reg_quality_standards", "nice_looked_after_children"],
      "internal_source_ids": ["indicare_record_dignity"],
      "evidence_strength": "high"
    },
    {
      "element": "diagnosis",
      "what_is_prohibited": "Clinical or diagnostic labels without qualified context.",
      "external_source_ids": ["swe_professional_standards", "nice_looked_after_children"],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "assumptions presented as fact",
      "what_is_prohibited": "Interpretation stated as certainty without evidence.",
      "external_source_ids": ["swe_professional_standards", "basw_code_ethics"],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "medium"
    },
    {
      "element": "punitive wording",
      "what_is_prohibited": "Non-compliant, naughty, defiant or similar punitive framing.",
      "external_source_ids": ["trauma_informed_principles", "pace_principles"],
      "internal_source_ids": ["indicare_record_dignity"],
      "evidence_strength": "medium"
    },
    {
      "element": "compliance guarantee",
      "what_is_prohibited": "Guaranteeing inspection or regulatory outcomes.",
      "external_source_ids": ["ofsted_sccif_ch"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "overclaiming compliance",
      "what_is_prohibited": "Asserting full compliance without evidence basis.",
      "external_source_ids": ["ofsted_ch_inspection_guidance"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "replacing safeguarding decision-making",
      "what_is_prohibited": "Instructing not to report, keep secret, or bypass DSL/manager.",
      "external_source_ids": ["working_together_2023", "nspcc_safeguarding_guidance"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "replacing professional judgement",
      "what_is_prohibited": "AI making threshold or action decisions for professionals.",
      "external_source_ids": ["swe_professional_standards", "working_together_2023"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "investigate further",
      "what_is_prohibited": "Frontline staff conducting investigations beyond their role on disclosures.",
      "external_source_ids": ["working_together_2023", "nspcc_safeguarding_guidance"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "confirmed abuse",
      "what_is_prohibited": "Stating abuse as confirmed without appropriate process.",
      "external_source_ids": ["working_together_2023"],
      "internal_source_ids": ["orb_adult_responsibility_boundary"],
      "evidence_strength": "high"
    },
    {
      "element": "invented facts",
      "what_is_prohibited": "Fabricating events, contacts or outcomes not in input.",
      "external_source_ids": ["guide_ch_reg_quality_standards", "swe_professional_standards"],
      "internal_source_ids": ["indicare_therapeutic_recording"],
      "evidence_strength": "high"
    },
    {
      "element": "unnecessary identifiable information",
      "what_is_prohibited": "Including identifiers beyond organisational minimum necessary.",
      "external_source_ids": ["dpa_2018", "uk_gdpr"],
      "internal_source_ids": ["orb_privacy_minimisation"],
      "evidence_strength": "high"
    }
  ],
