APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql://username:password@localhost:5432/childrens_homes
SESSION_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=replace-with-openai-key

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://indicare-frontend-next.onrender.com,https://app.indicare.co.uk,https://api.indicare.co.uk
ALLOWED_HOSTS=localhost,127.0.0.1

COOKIE_SECURE=false
COOKIE_SAMESITE=strict
ENABLE_HTTPS_REDIRECT=false
ENABLE_TRUSTED_HOSTS=false

OPENAI_MODEL=gpt-4o-mini
INDICARE_LLM_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_TEXT_MODEL=
AI_DEFAULT_FAST_MODEL=
AI_DEFAULT_REASONING_MODEL=
AI_DEFAULT_VISION_MODEL=
AI_DEFAULT_LOW_COST_MODEL=
AI_PROVIDER_STRICT=false
OPENAI_DEFAULT_MODEL=
OPENAI_FAST_MODEL=
OPENAI_REASONING_MODEL=
OPENAI_VISION_MODEL=
OPENAI_LOW_COST_MODEL=
OPENAI_TIMEOUT_SECONDS=45

TAVILY_API_KEY=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
APP_REVISION=local-dev

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
APP_BASE_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:8000

DB_POOL_MIN=2
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=15000
DB_IDLE_TX_TIMEOUT_MS=15000

AUTH_THROTTLE_WINDOW_SECONDS=900
AUTH_MAX_FAILED_ATTEMPTS_PER_IP=20
AUTH_MAX_FAILED_ATTEMPTS_PER_EMAIL=8
AUTH_LOCKOUT_SECONDS=900

GUIDANCE_SEARCH_TIMEOUT_SECONDS=3.0
WEB_SEARCH_CACHE_TTL_SECONDS=900
WEB_SEARCH_MAX_SNIPPET_CHARS=320
WEB_SEARCH_PRIMARY_LIMIT=4
WEB_SEARCH_SECONDARY_LIMIT=2
WEB_SEARCH_MIN_PRIMARY_RESULTS=2

FIRST_ADMIN_EMAIL=admin@indicare.co.uk
FIRST_ADMIN_PASSWORD=ChangeMe123456
FIRST_ADMIN_FIRST_NAME=System
FIRST_ADMIN_LAST_NAME=Admin
FIRST_ADMIN_ROLE=admin
FIRST_ADMIN_HOME_ID=

# Premium ORB Voice TTS (ORB Residential iOS spoken-reply playback)
ORB_TTS_ENABLED=false
ORB_TTS_PROVIDER=openai
ORB_TTS_DEFAULT_VOICE_ID=orb_british_female
ORB_TTS_DEFAULT_STYLE=calm_therapeutic
ORB_TTS_MODEL=tts-1-hd
ORB_TTS_MAX_TEXT_CHARS=500
ORB_TTS_TIMEOUT_SECONDS=20
